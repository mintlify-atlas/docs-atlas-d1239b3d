  "keyFeatures": [
    "Event catalog with seat management",
    "Distributed seat reservation with Redis locks",
    "Event-driven order processing via Kafka",
    "CQRS pattern for read/write separation",
    "Hexagonal architecture for maintainability",
    "Multi-service microservices design",
    "Async ticket fulfillment pipeline",
    "Real-time reservation expiration handling"
  ],
  "publicApiSurface": [
    "GET /events - List all events",
    "GET /events/{id} - Get event details",
    "GET /events/{id}/seatmap - Get event with seat availability",
    "POST /reservations - Reserve a seat (30min TTL)",
    "GET /reservations/{id} - Get reservation status",
    "POST /cart/add - Add reserved seat to cart",
    "POST /orders/checkout - Finalize order and trigger payment",
    "GET /orders/{id} - Get order details",
    "POST /payments - Process payment",
    "GET /tickets/{orderId} - Retrieve issued tickets"
  ]
